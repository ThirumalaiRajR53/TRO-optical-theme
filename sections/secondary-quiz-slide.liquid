{{ 'section-main-quiz.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
    }
  }
{%- endstyle -%}

<section
  class="section-{{ section.id }}-padding quiz quiz-slide-section twcss-flex-1"
  id="section-{{ section.index0 }}"
  data-filter-group="{{ section.settings.filter_group }}"
  data-final-step="{{ section.settings.is_final_step }}"
>
  <div class="page-width twcss-w-full twcss-flex twcss-justify-center">
    <div
      class="twcss-flex twcss-flex-col twcss-items-center twcss-bg-[rgb(var(--color-base-background-1))] twcss-p-5 md:twcss-p-[3.75rem]"
    >
      <h2 class="twcss-font-bold twcss-text-[2rem] twcss-text-center">{{ section.settings.question }}</h2>
      <div class="twcss-my-10 twcss-flex twcss-flex-wrap twcss-justify-center twcss-gap-3 md:twcss-gap-5">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'answer' %}
              {% if block.settings.answer_content != blank %}
                <button
                  type="button"
                  class="secondary-quiz-answer quiz-answer-option twcss-bg-transparent twcss-cursor-pointer twcss-border twcss-py-3 md:twcss-py-[1.125rem] twcss-px-6 md:twcss-px-[1.875rem]"
                  {{ block.shopify_attributes }}
                  data-answer-value="{{ block.settings.answer_value | escape }}"
                >
                  {% if block.settings.image != blank %}
                    <div class="twcss-h-20 sm:twcss-h-[6.25rem] twcss-w-20 sm:twcss-w-[6.25rem] twcss-mb-3">
                      {{
                        block.settings.image
                        | image_url: width: 100
                        | image_tag: class: 'twcss-object-contain twcss-h-full twcss-rounded-full', loading: 'lazy'
                      }}
                    </div>
                  {% endif %}
                  <div class="twcss-font-bold twcss-text-center">{{ block.settings.answer_content }}</div>
                </button>
              {% endif %}
          {% endcase %}
        {% endfor %}
      </div>
      <div class="twcss-flex twcss-flex-col sm:twcss-flex-row twcss-gap-3 sm:twcss-gap-5 twcss-w-full sm:twcss-w-[23.75rem]">
        <button
          type="button"
          class="next-slide next-button button button--primary button--small twcss-uppercase twcss-flex-1"
          disabled="disabled"
          {% if section.settings.is_final_step %}data-submit-quiz="true"{% endif %}
        >
          {% if section.settings.is_final_step %}Show my matches{% else %}Next{% endif %}
        </button>
        <button
          type="button"
          class="next-slide skip-button button button--secondary button--small twcss-uppercase twcss-flex-1"
          {% if section.settings.is_final_step %}data-submit-quiz="true"{% endif %}
        >
          {% if section.settings.is_final_step %}No brand preference{% else %}Skip{% endif %}
        </button>
      </div>
      {% if section.settings.is_final_step %}
        <p class="quiz-status twcss-mt-5 twcss-text-center" role="status" aria-live="polite"></p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.secondary_quiz_slide.name",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "question",
      "label": "t:sections.secondary_quiz_slide.settings.question.label",
      "default": "Your quiz question"
    },
    {
      "type": "select",
      "id": "filter_group",
      "label": "Recommendation field",
      "info": "Determines how this answer is used to build the collection filter URL.",
      "options": [
        { "value": "collection", "label": "Product type" },
        { "value": "gender", "label": "Gender" },
        { "value": "rim_type", "label": "Rim type" },
        { "value": "shape", "label": "Frame shape" },
        { "value": "color", "label": "Color" },
        { "value": "price", "label": "Price range" },
        { "value": "vendor", "label": "Brand" }
      ],
      "default": "shape"
    },
    {
      "type": "checkbox",
      "id": "is_final_step",
      "label": "Show recommendations after this question",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 130
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 130
    }
  ],
  "blocks": [
    {
      "type": "answer",
      "name": "t:sections.secondary_quiz_slide.blocks.answer.name",
      "settings": [
        {
          "type": "text",
          "id": "answer_content",
          "label": "t:sections.secondary_quiz_slide.blocks.answer.settings.answer_content.label",
          "default": "Quiz answer",
          "info": "t:sections.secondary_quiz_slide.blocks.answer.settings.answer_content.info"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.secondary_quiz_slide.blocks.answer.settings.image.label"
        },
        {
          "type": "text",
          "id": "answer_value",
          "label": "Recommendation value",
          "info": "Use exact Shopify filter values. Separate OR values with |. For prices use minimum|maximum. Leave blank for no preference."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.secondary_quiz_slide.presets.name",
      "blocks": [
        {
          "type": "answer"
        },
        {
          "type": "answer"
        },
        {
          "type": "answer"
        }
      ]
    }
  ]
}
{% endschema %}
