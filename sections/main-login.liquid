{{ 'customer.css' | asset_url | stylesheet_tag }}

<script src="{{ 'login.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .section-{{ section.id }}-border {
    border-color: rgba(var(--color-base-{{ section.settings.color_scheme }}),0.5);
    /* border-color: {{ section.settings.body_text }}; */
  }

  .text-{{ section.id }}-color {
    color: rgb(var(--color-base-{{ section.settings.color_scheme }}));
    /* border-color: {{ section.settings.body_text }}; */
  }


  .text-{{ section.id }}-color:hover {
    color: rgb(var(--color-base-accent-1));
    filter: brightness(0.85);
  }
{%- endstyle -%}

{% comment %} OLDER CODE --- MIGHT NEED THIS LATER {% endcomment %}
{% comment %}
  <div class="customer login section-{{ section.id }}-padding">
    <h1 id="recover" tabindex="-1">
      {{ 'customer.recover_password.title' | t }}
    </h1>
    <div>
      <p>
        {{ 'customer.recover_password.subtext' | t }}
      </p>

      {%- form 'recover_customer_password' -%}
        {% assign recover_success = form.posted_successfully? %}
        <div class="field">
          <input
            type="email"
            value=""
            name="email"
            id="RecoverEmail"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="RecoverEmail-email-error"
              autofocus
            {% endif %}
            placeholder="{{ 'customer.login_page.email' | t }}"
          >
          <label for="RecoverEmail">
            {{ 'customer.login_page.email' | t }}
          </label>
        </div>
        {%- if form.errors -%}
          <small id="RecoverEmail-email-error" class="form__message">
            <svg aria-hidden="true" focusable="false" viewBox="0 0 13 13">
              <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
              <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
              <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
              <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
            </svg>
            {{ form.errors.messages.form }}
          </small>
        {%- endif -%}

        <button>
          {{ 'customer.login_page.submit' | t }}
        </button>

        <a href="#login">
          {{ 'customer.login_page.cancel' | t }}
        </a>
      {%- endform -%}
    </div>

    <h1 id="login" tabindex="-1">
      {{ 'customer.login_page.title' | t }}
    </h1>
    <div>
      {%- if recover_success == true -%}
        <h3 class="form__message" tabindex="-1" autofocus>
          <svg aria-hidden="true" focusable="false" viewBox="0 0 13 13">
            <path d="M6.5 12.35C9.73087 12.35 12.35 9.73086 12.35 6.5C12.35 3.26913 9.73087 0.65 6.5 0.65C3.26913 0.65 0.65 3.26913 0.65 6.5C0.65 9.73086 3.26913 12.35 6.5 12.35Z" fill="#428445" stroke="white" stroke-width="0.7"/>
            <path d="M5.53271 8.66357L9.25213 4.68197" stroke="white"/>
            <path d="M4.10645 6.7688L6.13766 8.62553" stroke="white">
          </svg>
          {{ 'customer.recover_password.success' | t }}
        </h3>
      {%- endif -%}
      {%- form 'customer_login', novalidate: 'novalidate' -%}
        {%- if form.errors -%}
          <h2 class="form__message" tabindex="-1" autofocus>
            <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
            <svg aria-hidden="true" focusable="false" viewBox="0 0 13 13">
              <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
              <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
              <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
              <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
            </svg>
            {{ 'templates.contact.form.error_heading' | t }}
          </h2>
          {{ form.errors | default_errors }}
        {%- endif -%}

        <div class="field">
          <input
            type="email"
            name="customer[email]"
            id="CustomerEmail"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            {% if form.errors contains 'form' %}
              aria-invalid="true"
            {% endif %}
            placeholder="{{ 'customer.login_page.email' | t }}"
          >
          <label for="CustomerEmail">
            {{ 'customer.login_page.email' | t }}
          </label>
        </div>

        {%- if form.password_needed -%}
          <div class="field">
            <input
              type="password"
              value=""
              name="customer[password]"
              id="CustomerPassword"
              autocomplete="current-password"
              {% if form.errors contains 'form' %}
                aria-invalid="true"
              {% endif %}
              placeholder="{{ 'customer.login_page.password' | t }}"
            >
            <label for="CustomerPassword">
              {{ 'customer.login_page.password' | t }}
            </label>
          </div>

          <a href="#recover">
            {{ 'customer.login_page.forgot_password' | t }}
          </a>
        {%- endif -%}

        <button>
          {{ 'customer.login_page.sign_in' | t }}
        </button>

        <a href="{{ routes.account_register_url }}">
          {{ 'customer.login_page.create_account' | t }}
        </a>
      {%- endform -%}
    </div>

    {%- if shop.checkout.guest_login -%}
      <div>
        <hr>
        <h2>{{ 'customer.login_page.guest_title' | t }}</h2>

        {%- form 'guest_login' -%}
          <button>
            {{ 'customer.login_page.guest_continue' | t }}
          </button>
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>
{% endcomment %}
{% comment %} END OF OLDER CODE --- MIGHT NEED THIS LATER {% endcomment %}

<section class="twcss-bg-slate-50 twcss-pb-[4.375rem] twcss-pt-[3.125rem]">
  <div class="twcss-mx-auto twcss-flex twcss-justify-center ">
    <div id="recover" tabindex="-1">
      <div class="twcss-flex twcss-border-b twcss-border-slate-200 color-background-1 isolate">
        <div class=" twcss-px-[4.375rem] twcss-py-10 customer">
          <h2 class="twcss-text-heading twcss-mb-4 twcss-text-center twcss-text-3xl twcss-font-semibold">
            {{ 'customer.recover_password.title' | t }}
          </h2>
          <p class="twcss-text-body-text twcss-mb-5 twcss-px-[1.875rem] twcss-text-center twcss-text-sm">
            {{ 'customer.recover_password.subtext' | t }}
          </p>
          {%- form 'recover_customer_password', novalidate: 'novalidate' -%}
            {% assign recover_success = form.posted_successfully? %}
            <div class="field">
              <input
                type="email"
                value=""
                name="email"
                id="RecoverEmail"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="RecoverEmail-email-error"
                  autofocus
                {% endif %}
                placeholder="{{ 'customer.login_page.email' | t }}"
                class="input-border input-placeholder twcss-w-full twcss-px-3 twcss-py-[0.875rem]"
              >
            </div>
            {%- if form.errors -%}
              <small id="RecoverEmail-email-error" class="form__message twcss-text-red-400">
                {{ form.errors.messages.form }}
              </small>
            {%- endif -%}

            <button
              class=" button button--primary twcss-mt-7 twcss-w-full twcss-uppercase"
            >
              {{ 'customer.login_page.submit' | t }}
            </button>

            <a
              href="#login"
              class="button button--secondary twcss-text-center twcss-w-full twcss-uppercase"
            >
              {{ 'customer.login_page.cancel' | t }}
            </a>
          {%- endform -%}
        </div>
      </div>
    </div>

    <h1 id="login" tabindex="" class="twcss-hidden">
      {{ 'customer.login_page.title' | t }}
    </h1>

    <div class=" twcss-w-11/12 color-background-1 isolate md:twcss-w-3/4 lg:twcss-w-1/2">
      <div class="twcss-flex twcss-border-b twcss-border-slate-200">
        <a
          href="{{ routes.account_login_url }}"
          class="section-{{ section.id }}-border twcss-w-full twcss-border-b-2 twcss-py-5"
        >
          <h3 class="twcss-text-center twcss-text-lg twcss-font-semibold md:twcss-text-xl">
            {{ 'customer.login_page.sign_in' | t | upcase }}
          </h3>
        </a>

        <a
          href="{{ routes.account_register_url }}"
          class="twcss-w-full twcss-py-5"
        >
          <h3 class="twcss-text-center twcss-text-lg twcss-font-semibold twcss-opacity-[0.7] md:twcss-text-xl">
            {{ 'customer.register.sign_up' | t | upcase }}
          </h3>
        </a>
      </div>

      <div class="twcss-px-5  twcss-py-10 lg:twcss-px-[4.375rem]">
        {%- if recover_success == true -%}
          <h3 class="twcss-py-2 twcss-text-center twcss-text-sm twcss-text-blue-600" tabindex="-1" autofocus>
            {{ 'customer.recover_password.success' | t }}
          </h3>
        {%- endif -%}

        <h2 class="twcss-text-heading twcss-mb-4 twcss-text-center twcss-text-2xl twcss-font-semibold twcss-leading-[2.625rem] md:twcss-text-[2rem]">
          {{ 'customer.login_page.title' | t }}
        </h2>
        <p class="twcss-text-body-text twcss-mb-5 twcss-text-center twcss-text-sm twcss-leading-[1.375rem]">
          {{ 'customer.login_page.sub_heading' | t }}
        </p>

        <div class="login-form customer">
          {%- form 'customer_login', novalidate: 'novalidate' -%}
            <div class="field">
              <input
                type="email"
                name="customer[email]"
                id="form-login-email"
                placeholder="{{ 'customer.login_page.email' | t }}"
                class="input-border input-placeholder twcss-w-full twcss-border  twcss-px-3 twcss-py-[0.875rem] twcss-leading-[1.625rem]   "
              >
            </div>

            <div class="twcss-relative twcss-mt-5 field">
              <input
                type="password"
                name="customer[password]"
                value=""
                id="form-login-password"
                placeholder="{{ 'customer.login_page.password' | t }}"
                class="input-border input-placeholder twcss-w-full twcss-px-3 twcss-py-[0.875rem] twcss-leading-[1.625rem]"
              >
              <div class=" twcss-absolute twcss-right-4 twcss-top-1/2 twcss-h-7 -twcss-translate-y-1/2">
                <button
                  type="button"
                  id="toggle-pw-button"
                  class="twcss-h-full twcss-cursor-pointer "
                  loading="lazy"
                  data-eye=" true"
                >
                  <span class="eye-close">
                    {%- render 'icon-eye-close' -%}
                  </span>
                  <span class="eye-open">
                    {%- render 'icon-eye-open' -%}
                  </span>
                </button>
              </div>
            </div>

            {%- if form.errors -%}
              <span id="form-login-error" class="twcss-text-red-500">
                {{ form.errors | default_errors }}
              </span>
            {%- endif -%}

            <div class="relative twcss-mt-5 twcss-flex twcss-items-center twcss-justify-between">
              <label class="twcss-inline-flex twcss-items-center">
                <input
                  type="checkbox"
                  class=" twcss-mr-2 twcss-h-5 twcss-w-5 twcss-cursor-pointer twcss-bg-slate-300 checked:twcss-bg-red-500"
                  id="remember-me-checkbox"
                >
                <span class="twcss-text-sm twcss-opacity-80 twcss-cursor-pointer">
                  {{ 'customer.login_page.remember_me' | t }}
                </span>
              </label>
              <a
                href="#recover"
                class=" text-{{ section.id }}-color text-hover-color twcss-text-right twcss-text-sm twcss-font-semibold twcss-uppercase twcss-tracking-wider"
              >
                {{ 'customer.login_page.forgot_password' | t }}
              </a>
            </div>

            <button
              class="button button--primary twcss-my-4 twcss-w-full"
              onclick="rememberUsername()"
            >
              {{ 'customer.login_page.sign_in' | t }}
            </button>
          {% endform %}
        </div>

        <div class="terms-wrapper twcss-text-body-text twcss-mb-[1.875rem] twcss-text-center twcss-text-sm">
          {{ section.settings.tos_section }}
        </div>

        {% comment %}
          <div class="twcss-mb-[1.875rem] twcss-flex twcss-items-center twcss-gap-2">
            <hr class="twcss-m-0 twcss-w-full">
            <p class="twcss-w-full twcss-text-center twcss-text-sm twcss-font-semibold twcss-text-slate-600">
              Or Sign in with
            </p>
            <hr class="twcss-m-0 twcss-w-full">
          </div>
          <div class="twcss-flex twcss-flex-col twcss-gap-2.5 sm:twcss-flex-row">
            <div class="twcss-flex twcss-w-full twcss-items-center twcss-justify-center twcss-gap-2 twcss-rounded twcss-border twcss-border-slate-700 twcss-px-6 twcss-py-3.5">
              <button class="twcss-text-heading twcss-text-sm twcss-font-semibold">SIGN IN WITH FACEBOOK</button>
            </div>
            <div class="twcss-flex twcss-w-full twcss-items-center twcss-justify-center twcss-gap-2 twcss-rounded twcss-border twcss-border-slate-700 twcss-px-6 twcss-py-3.5">
              <button class="twcss-text-heading twcss-text-sm twcss-font-semibold">SIGN IN WITH GOOGLE</button>
            </div>
          </div>
        {% endcomment %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "t:sections.all.colors.accent_1.label"
        },
        {
          "value": "accent-2",
          "label": "t:sections.all.colors.accent_2.label"
        },
        {
          "value": "background-1",
          "label": "t:sections.all.colors.background_1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.all.colors.background_2.label"
        },
        {
          "value": "inverse",
          "label": "t:sections.all.colors.inverse.label"
        }
      ],
      "default": "accent-1",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "richtext",
      "id": "tos_section",
      "label": "t:sections.main-login.tos"
    }
  ]
}
{% endschema %}
