{{ 'section-image-with-heading.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
{% endstyle %}
<div class="page-width section-{{ section.id }}-padding image-with-heading-container">
  <div class="twcss-flex twcss-flex-col twcss-flex-wrap twcss-gap-6  twcss-px-5 md:twcss-flex-row">
    {% for block in section.blocks %}
      <div
        class=" image-with-heading-content twcss-relative twcss-flex twcss-items-center "
        {{ block.shopify_attributes }}
      >
        {% if block.settings.image != blank %}
          <div class="twcss-flex twcss-h-[3.75rem] twcss-w-[3.75rem] twcss-items-center twcss-rounded-full  twcss-bg-white twcss-ps-[0.625rem]">
            <div class="twcss-h-[1.75rem] twcss-w-[1.75rem]">
              {{
                block.settings.image
                | image_url: width: 300
                | image_tag: class: 'twcss-h-full twcss-w-full twcss-object-contain', loading: 'lazy'
              }}
            </div>
          </div>
        {% endif %}

        {% if block.settings.title != blank %}
          <p class="{% if block.settings.image != blank %}twcss-absolute twcss-left-11 {% endif %}  twcss-font-bold twcss-leading-[1.375rem]">
            {{ block.settings.title }}
          </p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>
{% schema %}
{
  "name": "t:sections.image_with_heading.name",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.image_with_heading.blocks.column.name",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.image_with_heading.blocks.column.settings.image.label"
        },

        {
          "type": "inline_richtext",
          "id": "title",
          "default": "Heading",
          "label": "t:sections.image_with_heading.blocks.column.settings.heading.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_with_heading.presets.name",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}
