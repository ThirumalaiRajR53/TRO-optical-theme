{{ 'section-main-quiz.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="twcss-flex twcss-flex-col md:twcss-flex-row md:twcss-justify-end twcss-relative md:twcss-h-[32.5rem]">
      {% if section.settings.image != blank %}
        <div class="twcss-h-[13.625rem] md:twcss-h-full md:twcss-w-[67%]">
          {{
            section.settings.image
            | image_url: width: 850, height: 520
            | image_tag: class: 'twcss-h-full twcss-object-cover', loading: 'lazy'
          }}
        </div>
      {% endif %}

      <div class="twcss-flex twcss-items-center md:twcss-absolute md:twcss-left-0 md:twcss-top-1/2 md:twcss-transform md:-twcss-translate-y-1/2 md:twcss-max-w-[28.375rem] twcss-bg-[rgb(var(--color-base-background-1))] quiz-info">
        <div class="twcss-p-10 twcss-flex twcss-flex-col twcss-border twcss-border-blue-900 ">
          <h2 class="twcss-font-semibold twcss-text-[1.625rem] md:twcss-text-[2.375rem]">
            {{ section.settings.heading }}
          </h2>
          <div class="twcss-mt-5 twcss-mb-10">{{ section.settings.description }}</div>
          {%- if section.settings.button_label != blank -%}
            <div>
              <a
                {% if section.settings.button_link == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ section.settings.button_link }}"
                {% endif %}
                class="button button--primary button--small twcss-uppercase md:twcss-w-fit"
              >
                {{- section.settings.button_label | escape -}}
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.quiz.name",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.quiz.settings.image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.quiz.settings.heading.label",
      "default": "Find Your Best Match"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.quiz.settings.description.label",
      "default": "<p>Need help looking for your perfect Readers, Sunglasses or Blue Light Filtering Eyewear? Take our quiz to find the best fit for you.<\/p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.quiz.settings.button_label.label",
      "default": "Take the quiz"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.quiz.settings.button_link.label"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "t:sections.quiz.presets.name"
    }
  ]
}
{% endschema %}
