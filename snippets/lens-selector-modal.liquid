{% comment %}
  Renders a three-step lens selection modal for eyeglass products.
  Step 1: Power Type (Frame Only, Single Vision, Computer, Progressive, Bifocal)
  Step 2: Lens Bundle (placeholder bundles with pricing)
  Step 3: Prescription (manual entry or upload after purchase)

  Accepts:
  - product: {Object} product object
  - product_form_id: {String} the product form ID to gate
  - section_id: {String} section ID for unique element IDs
{% endcomment %}

<link rel="stylesheet" href="{{ 'component-lens-selector.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-lens-selector.css' | asset_url | stylesheet_tag }}</noscript>

<dialog
  id="LensSelectorModal-{{ section_id }}"
  class="lens-modal"
  data-form-id="{{ product_form_id }}"
  data-frame-price="{{ product.selected_or_first_available_variant.price }}"
>
  <div class="lens-modal__container">
    <button type="button" class="lens-modal__close" data-lens-close aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>

    <div class="lens-modal__header">
      <h2 class="lens-modal__title">Select Lens Details</h2>
      <div class="lens-modal__stepper">
        <div class="lens-modal__step lens-modal__step--active" data-step-indicator="1">
          <span class="lens-modal__step-dot"></span>
          <span class="lens-modal__step-label">Power Type</span>
        </div>
        <div class="lens-modal__step-line"></div>
        <div class="lens-modal__step" data-step-indicator="2">
          <span class="lens-modal__step-dot"></span>
          <span class="lens-modal__step-label">Lens Type</span>
        </div>
        <div class="lens-modal__step-line"></div>
        <div class="lens-modal__step" data-step-indicator="3">
          <span class="lens-modal__step-dot"></span>
          <span class="lens-modal__step-label">Prescription</span>
        </div>
      </div>
      <div class="lens-modal__price-tag">
        <span id="LensPriceLabel-{{ section_id }}">Frame cost</span>
        <strong id="LensPriceValue-{{ section_id }}">{{ product.selected_or_first_available_variant.price | money }}</strong>
      </div>
    </div>

    <!-- Step 1: Power Type -->
    <div class="lens-modal__step-content lens-modal__step-content--active" data-step="1">
      <h3 class="lens-modal__section-title">Select Power Type</h3>
      <div class="lens-modal__power-grid">
        {%- assign power_types = 'Frame Only,Single Vision,Computer,Progressive,Bifocal' | split: ',' -%}
        {%- assign power_descs = 'Pick your favorite frame now and add lenses later.,For positive&comma; negative or intermediate power.,Optimized for screens&comma; less strain.,Smooth transition for near to distance vision.,Clear vision for both near and far.' | split: ',' -%}
        {%- for pt in power_types -%}
          <label class="lens-modal__card">
            <input type="radio" name="lens-power-type" value="{{ pt }}" class="lens-modal__radio">
            <div class="lens-modal__card-inner">
              <div class="lens-modal__card-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="1.2"><rect x="2" y="7" width="20" height="10" rx="5"/><circle cx="12" cy="12" r="2"/></svg>
              </div>
              <div class="lens-modal__card-text">
                <strong>{{ pt }}</strong>
                <span>{{ power_descs[forloop.index0] | replace: '&comma;', ',' }}</span>
              </div>
            </div>
          </label>
        {%- endfor -%}
      </div>
    </div>

    <!-- Step 2: Lens Bundle -->
    <div class="lens-modal__step-content" data-step="2">
      <div class="lens-modal__step2-header">
        <button type="button" class="lens-modal__back" data-lens-back="1">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          <span data-lens-power-label></span>
        </button>
      </div>
      <div class="lens-modal__power-toggle-bar">
        <h3 class="lens-modal__section-title" style="margin:0">Select Lens Package</h3>
        <div class="lens-modal__power-toggle-right">
          <span class="lens-modal__power-info-wrap">
            Lens Power
            <span class="lens-modal__power-info">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              <span class="lens-modal__power-tooltip">
                <strong>Low Power Lens</strong><br>
                SPH &minus;6 to +6 and CYL upto &minus;4<br><br>
                <strong>High Power Lens</strong><br>
                SPH &minus;16 to +9 and CYL upto &minus;6
              </span>
            </span>
          </span>
          <label class="lens-modal__toggle">
            <span class="lens-modal__toggle-label">Low</span>
            <input type="checkbox" id="LensPowerToggle-{{ section_id }}" class="lens-modal__toggle-input">
            <span class="lens-modal__toggle-track"></span>
            <span class="lens-modal__toggle-label">High</span>
          </label>
        </div>
      </div>
      <div class="lens-modal__lens-list" id="LensList-{{ section_id }}">
        <!-- ponytail: populated by JS from config JSON -->
      </div>
    </div>

    <!-- Step 3: Prescription -->
    <div class="lens-modal__step-content" data-step="3">
      <div class="lens-modal__step2-header">
        <button type="button" class="lens-modal__back" data-lens-back="2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Back to Lens Type
        </button>
      </div>
      <h3 class="lens-modal__section-title">Enter Your Prescription</h3>

      <div class="lens-modal__manual-rx lens-modal__manual-rx--visible" id="LensManualRx-{{ section_id }}">
        <div class="lens-modal__rx-grid">
          {%- for eye_i in (1..2) -%}
            {%- if eye_i == 1 -%}
              {%- assign eye_label = 'Left Eye (OS)' -%}
              {%- assign eye_id = 'left' -%}
            {%- else -%}
              {%- assign eye_label = 'Right Eye (OD)' -%}
              {%- assign eye_id = 'right' -%}
            {%- endif -%}
            <fieldset class="lens-modal__rx-eye">
              <legend>{{ eye_label }}</legend>
              <div class="lens-modal__rx-fields">
                <div class="lens-modal__rx-field">
                  <label for="lens-sph-{{ eye_id }}">SPH</label>
                  <select id="lens-sph-{{ eye_id }}" class="lens-modal__rx-select" data-rx-field="sph">
                    <option value="">Select</option>
                  </select>
                </div>
                <div class="lens-modal__rx-field">
                  <label for="lens-cyl-{{ eye_id }}">CYL</label>
                  <select id="lens-cyl-{{ eye_id }}" class="lens-modal__rx-select" data-rx-field="cyl">
                    <option value="">None</option>
                  </select>
                </div>
                <div class="lens-modal__rx-field">
                  <label for="lens-axis-{{ eye_id }}">Axis</label>
                  <input type="number" id="lens-axis-{{ eye_id }}" class="lens-modal__rx-input" data-rx-field="axis" min="1" max="180" placeholder="1-180">
                </div>
              </div>
            </fieldset>
          {%- endfor -%}
        </div>
      </div>

      <div class="lens-modal__rx-error" id="LensRxError-{{ section_id }}" hidden>
        <span id="LensRxErrorText-{{ section_id }}">Please select SPH for at least one eye.</span>
      </div>

      <button type="button" class="lens-modal__submit-btn" data-lens-submit>
        Add to Cart
      </button>
      <button type="button" class="lens-modal__skip-btn" data-lens-skip>
        Skip to upload prescription post checkout
      </button>
    </div>
  </div>
</dialog>

<div id="LensLoadingOverlay" class="lens-loading-overlay" hidden>
  <span class="lens-loading-overlay__text">Please wait...</span>
</div>

