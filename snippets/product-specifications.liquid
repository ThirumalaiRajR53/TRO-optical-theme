{% comment %}
  Renders product specifications for optical products.
  Automatically detects product type (frames vs contact lenses) and shows
  the appropriate specs. Reads from product metafields under 'custom' namespace.

  Accepts:
  - product: {Object} Product Liquid object

  Usage:
  {% render 'product-specifications', product: product %}
{% endcomment %}

{%- liquid
  comment
    Frame metafields
  endcomment
  assign frame_width = product.metafields.custom.frame_width.value
  assign bridge_width = product.metafields.custom.bridge_width.value
  assign temple_length = product.metafields.custom.temple_length.value
  assign lens_width = product.metafields.custom.lens_width.value
  assign lens_height = product.metafields.custom.lens_height.value
  assign frame_material = product.metafields.custom.frame_material.value
  assign frame_shape = product.metafields.custom.frame_shape.value
  assign frame_weight = product.metafields.custom.frame_weight.value
  assign lens_compatibility = product.metafields.custom.lens_type_compatibility.value

  comment
    Contact lens metafields
  endcomment
  assign cl_base_curve = product.metafields.custom.base_curve.value
  assign cl_diameter = product.metafields.custom.diameter.value
  assign cl_water_content = product.metafields.custom.water_content.value
  assign cl_dk_value = product.metafields.custom.dk_value.value
  assign cl_material = product.metafields.custom.lens_material.value
  assign cl_replacement = product.metafields.custom.replacement_schedule.value
  assign cl_wear_type = product.metafields.custom.wear_type.value
  assign cl_uv_protection = product.metafields.custom.uv_protection.value
  assign cl_pack_sizes = product.metafields.custom.available_pack_sizes.value

  comment
    Determine product type
  endcomment
  assign has_frame_specs = false
  if frame_width or bridge_width or temple_length or lens_width or lens_height or frame_material or frame_shape or frame_weight or lens_compatibility
    assign has_frame_specs = true
  endif

  assign has_contact_specs = false
  if cl_base_curve or cl_diameter or cl_water_content or cl_dk_value or cl_material or cl_replacement or cl_wear_type or cl_uv_protection
    assign has_contact_specs = true
  endif

  assign has_any_specs = false
  if has_frame_specs or has_contact_specs
    assign has_any_specs = true
  endif
-%}

{%- if has_any_specs -%}
  {%- if has_contact_specs -%}
    {%- comment -%} Contact Lens Specifications {%- endcomment -%}
    <div class="product-specs product-specs--contact-lens">
      <div class="product-specs__header">
        <svg class="product-specs__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="9"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
        </svg>
        <span class="product-specs__title">Lens Specifications</span>
      </div>

      <div class="product-specs__lens-params">
        <div class="product-specs__grid">
          {%- if cl_base_curve -%}
            <div class="product-specs__item">
              <span class="product-specs__label">Base Curve (BC)</span>
              <span class="product-specs__value">{{ cl_base_curve }} mm</span>
            </div>
          {%- endif -%}
          {%- if cl_diameter -%}
            <div class="product-specs__item">
              <span class="product-specs__label">Diameter (DIA)</span>
              <span class="product-specs__value">{{ cl_diameter }} mm</span>
            </div>
          {%- endif -%}
          {%- if cl_water_content -%}
            <div class="product-specs__item">
              <span class="product-specs__label">Water Content</span>
              <span class="product-specs__value">{{ cl_water_content }}%</span>
            </div>
          {%- endif -%}
          {%- if cl_dk_value -%}
            <div class="product-specs__item">
              <span class="product-specs__label">Dk/t (Oxygen)</span>
              <span class="product-specs__value">{{ cl_dk_value }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- if cl_material or cl_replacement or cl_wear_type or cl_uv_protection -%}
        <div class="product-specs__details">
          {%- if cl_material -%}
            <div class="product-specs__detail-row">
              <span class="product-specs__label">Material</span>
              <span class="product-specs__value product-specs__badge">{{ cl_material }}</span>
            </div>
          {%- endif -%}
          {%- if cl_replacement -%}
            <div class="product-specs__detail-row">
              <span class="product-specs__label">Replacement</span>
              <span class="product-specs__value product-specs__badge">{{ cl_replacement }}</span>
            </div>
          {%- endif -%}
          {%- if cl_wear_type -%}
            <div class="product-specs__detail-row">
              <span class="product-specs__label">Wear Type</span>
              <span class="product-specs__value product-specs__badge">{{ cl_wear_type }}</span>
            </div>
          {%- endif -%}
          {%- if cl_uv_protection -%}
            <div class="product-specs__detail-row">
              <span class="product-specs__label">UV Protection</span>
              <span class="product-specs__value">
                {%- if cl_uv_protection == 'true' or cl_uv_protection == true -%}
                  <span class="product-specs__tag product-specs__tag--positive">Yes</span>
                {%- else -%}
                  <span class="product-specs__tag">{{ cl_uv_protection }}</span>
                {%- endif -%}
              </span>
            </div>
          {%- endif -%}
          {%- if cl_pack_sizes -%}
            <div class="product-specs__detail-row">
              <span class="product-specs__label">Pack Sizes</span>
              <span class="product-specs__value">
                {%- for pack in cl_pack_sizes -%}
                  <span class="product-specs__tag">{{ pack }}</span>
                {%- endfor -%}
              </span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="product-specs__note">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 16v-4"/>
          <path d="M12 8h.01"/>
        </svg>
        <span>A valid prescription is required. Please consult your eye care professional.</span>
      </div>
    </div>

  {%- endif -%}

  {%- if has_frame_specs -%}
    {%- comment -%} Frame Specifications {%- endcomment -%}
    <div class="product-specs product-specs--frames">
      <div class="product-specs__header">
        <svg class="product-specs__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        <span class="product-specs__title">Frame Specifications</span>
      </div>

      {%- assign has_measurements = false -%}
      {%- if frame_width or bridge_width or temple_length or lens_width or lens_height -%}
        {%- assign has_measurements = true -%}
      {%- endif -%}

      {%- if has_measurements -%}
        <div class="product-specs__measurements">
          <div class="product-specs__diagram">
            <svg viewBox="0 0 200 80" class="product-specs__frame-diagram" aria-label="Frame measurement diagram">
              <rect x="10" y="20" width="70" height="40" rx="8" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <rect x="120" y="20" width="70" height="40" rx="8" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M80 35 L120 35" stroke="currentColor" stroke-width="1.5"/>
              <path d="M10 60 L10 68 L80 68 L80 60" stroke="currentColor" stroke-width="1" stroke-dasharray="2,2"/>
              <path d="M80 60 L80 68 L120 68 L120 60" stroke="currentColor" stroke-width="1" stroke-dasharray="2,2"/>
              {%- if lens_width -%}
                <text x="45" y="78" text-anchor="middle" class="product-specs__diagram-label">{{ lens_width }}mm</text>
              {%- endif -%}
              {%- if bridge_width -%}
                <text x="100" y="78" text-anchor="middle" class="product-specs__diagram-label">{{ bridge_width }}mm</text>
              {%- endif -%}
            </svg>
          </div>
          <div class="product-specs__grid">
            {%- if lens_width -%}
              <div class="product-specs__item">
                <span class="product-specs__label">Lens Width</span>
                <span class="product-specs__value">{{ lens_width }} mm</span>
              </div>
            {%- endif -%}
            {%- if bridge_width -%}
              <div class="product-specs__item">
                <span class="product-specs__label">Bridge Width</span>
                <span class="product-specs__value">{{ bridge_width }} mm</span>
              </div>
            {%- endif -%}
            {%- if temple_length -%}
              <div class="product-specs__item">
                <span class="product-specs__label">Temple Length</span>
                <span class="product-specs__value">{{ temple_length }} mm</span>
              </div>
            {%- endif -%}
            {%- if frame_width -%}
              <div class="product-specs__item">
                <span class="product-specs__label">Frame Width</span>
                <span class="product-specs__value">{{ frame_width }} mm</span>
              </div>
            {%- endif -%}
            {%- if lens_height -%}
              <div class="product-specs__item">
                <span class="product-specs__label">Lens Height</span>
                <span class="product-specs__value">{{ lens_height }} mm</span>
              </div>
            {%- endif -%}
            {%- if frame_weight -%}
              <div class="product-specs__item">
                <span class="product-specs__label">Weight</span>
                <span class="product-specs__value">{{ frame_weight }} g</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- if frame_material or frame_shape or lens_compatibility -%}
        <div class="product-specs__details">
          {%- if frame_material -%}
            <div class="product-specs__detail-row">
              <span class="product-specs__label">Material</span>
              <span class="product-specs__value product-specs__badge">{{ frame_material }}</span>
            </div>
          {%- endif -%}
          {%- if frame_shape -%}
            <div class="product-specs__detail-row">
              <span class="product-specs__label">Shape</span>
              <span class="product-specs__value product-specs__badge">{{ frame_shape }}</span>
            </div>
          {%- endif -%}
          {%- if lens_compatibility -%}
            <div class="product-specs__detail-row">
              <span class="product-specs__label">Lens Types</span>
              <span class="product-specs__value">
                {%- for lens_type in lens_compatibility -%}
                  <span class="product-specs__tag">{{ lens_type }}</span>
                {%- endfor -%}
              </span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endif -%}
